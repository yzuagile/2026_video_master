<Window x:Class="framework.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VideoMaster 2026 剪輯軟體" Height="650" Width="1050">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#333333" VerticalAlignment="Center">
            <Button Name="BtnImport" Content="📁 匯入影片" Margin="15,0,5,0" Padding="15,5" Background="White" Click="BtnImport_Click"/>
            <Button Name="BtnExport" Content="🎬 輸出影片" Margin="5,0,0,0" Padding="15,5" Background="#007ACC" Foreground="White" BorderBrush="{x:Null}" Click="BtnExport_Click"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="10">
                <Border Background="Black">
                    <MediaElement Name="VideoPlayer" LoadedBehavior="Manual" Stretch="Uniform"/>
                </Border>

                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Name="BtnPlay" Content="播放 ▶" Margin="5" Width="70" Click="BtnPlay_Click"/>
                    <Button Name="BtnPause" Content="暫停 ⏸" Margin="5" Width="70" Click="BtnPause_Click"/>
                </StackPanel>
            </Grid>

            <TabControl Grid.Column="1" Margin="10">

                <TabItem Header="📝 字卡設定" FontSize="14">
                    <StackPanel Margin="15">
                        <TextBlock Text="🎬 字卡設定面板" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        <TextBlock Text="請輸入字幕內容：" Margin="0,0,0,5"/>
                        <TextBox Name="TxtSubtitle" Height="80" TextWrapping="Wrap" Margin="0,0,0,15" AcceptsReturn="True"/>
                        <Button Name="BtnAddText" Content="套用字卡設定" Padding="8" Click="BtnAddText_Click"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="✂️ 影像剪輯" FontSize="14">
                    <StackPanel Margin="15">
                        <TextBlock Text="✂️ 剪輯設定面板" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        <TextBlock Text="設定剪輯保留區間：" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="開始時間 (秒)：" VerticalAlignment="Center" Width="100"/>
                            <TextBox Name="TxtStartTime" Width="60" Text="0" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="結束時間 (秒)：" VerticalAlignment="Center" Width="100"/>
                            <TextBox Name="TxtEndTime" Width="60" Text="10" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <Button Name="BtnTrim" Content="設定剪輯標記" Padding="8" Click="BtnTrim_Click"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="🎨 畫面調整" FontSize="14">
                    <StackPanel Margin="15" VerticalAlignment="Center">
                        <TextBlock Text="此區塊未來可放置亮度、對比、濾鏡等設定..." Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </TabItem>

            </TabControl>
        </Grid>

        <Border Grid.Row="2" Background="#252526" Margin="10,0,10,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel Name="TimelineContentStack" Orientation="Vertical" HorizontalAlignment="Left" Background="Transparent" MouseDown="VideoTrackCanvas_MouseDown">
                    <StackPanel Orientation="Horizontal" Background="#2D2D2D">
                        <RadioButton Name="ToolSelect" Content="🏹 選取 (V)" IsChecked="True" Margin="5" Foreground="White"/>
                        <RadioButton Name="ToolRazor" Content="✂️ 剪刀 (C)" Margin="5" Foreground="White"/>
                        <Button x:Name="BtnDelete" Content="✖ 刪除 (Del)" Click="BtnDelete_Click" 
            Margin="10,5,5,5" Padding="10,0" 
            Background="Transparent" Foreground="White" BorderThickness="0" 
            Cursor="Hand"/>
                    </StackPanel>

                    <Grid Height="25" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Canvas Grid.Column="1" Name="TimeRulerCanvas" Background="#2D2D2D" HorizontalAlignment="Left"/>
                    </Grid>

                    <Grid Height="40" Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🎬 影像軌" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Canvas Grid.Column="1" Name="VideoTrackCanvas" Background="#1E1E1E" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>